{
  "name": "invest",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "bun run src/main.ts",
    "fetch:all": "bun run src/fetch-all.ts",
    "fetch:history": "bun run src/fetch-history.ts",
    "fetch:long-history": "bun run src/fetch-long-history.ts",
    "fetch:vietnam": "bun run src/sources/vietnam/index.ts",
    "fetch:vietnam-history": "bun run src/sources/vietnam/history.ts",
    "fetch:world": "bun run src/sources/international/index.ts",
    "fetch:twelvedata": "bun run src/sources/twelvedata/index.ts",
    "fetch:china": "bun run src/sources/china/index.ts",
    "fetch:russia": "bun run src/sources/russia/index.ts",
    "fetch:india": "bun run src/sources/india/index.ts",
    "fetch:exchange-rate": "bun run src/sources/exchange-rate/index.ts",
    "fetch:first-principles": "bun run src/fetch-first-principles.ts",
    "collect:daily": "bun run src/collect-daily.ts",
    "analyze:drawdowns": "bun run src/analyze-drawdowns.ts",
    "ai:suggest": "bun run src/generate-ai-suggestion.ts",
    "backfill": "bun run src/backfill.ts",
    "verify:first-principles": "bun run src/verify-first-principles.ts --strict",
    "test": "bun test",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0",
    "@types/cheerio": "^0.22.35"
  }
}
